{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Slaim",
  "version": "0.1.5",
  "identifier": "com.slaim.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Slaim",
        "width": 1280,
        "height": 810,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyQUMyNjFCNTBFOTcwNEMKUldSTWNPbFFHeWFzc3B6L1duK2ZMOTI5Rm5kTjdiM2o5ZkhmenlJQUFhSVJob0pWalNjWjhGd2MK",
      "endpoints": [
        "https://github.com/EdinsonNM/slides-for-devs/releases/latest/download/latest.json"
      ]
    }
  }
}