{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": ["$APPDATA/**", "$APPDATA/*"]
    }
  ]
}
