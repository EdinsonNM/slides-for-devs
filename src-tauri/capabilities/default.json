{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window including create webview window",
  "windows": ["main", "presenter"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "fs:default",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-write-recursive",
    {
      "identifier": "fs:scope",
      "allow": ["$APPDATA/**", "$APPDATA/*"]
    },
    "updater:default",
    "dialog:default",
    "process:default",
    "process:allow-restart"
  ]
}
